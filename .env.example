# Configurações do Bot de Trading
# Copie este arquivo para .env e configure suas chaves da API

# Chaves da API Bybit (obtenha em https://www.bybit.com/app/user/api-management)
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Modo de teste (true = testnet, false = produção)
TESTNET=true

# Configurações opcionais
MIN_BALANCE=10.0
POSITION_SIZE_PCT=0.01
MAX_POSITIONS=3